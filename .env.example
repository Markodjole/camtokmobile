# CamTok mobile env
# Copy to .env and fill in before running `pnpm start`.

# URL of the deployed Next.js backend (from the camtok web app).
# Examples:
#   local dev on a simulator:   http://localhost:3000
#   local dev on a real device: http://192.168.1.42:3000   (your machine's LAN IP)
#   production:                 https://camtok.example.com
EXPO_PUBLIC_API_BASE_URL=https://camtok-web.vercel.app

# Supabase — same project that camtok web uses, the anon key only.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# WebRTC TURN (same values as camtok web / Vercel) — required for viewers on cellular NAT.
# EXPO_PUBLIC_TURN_URL=turn:your-host:3478
# EXPO_PUBLIC_TURN_USERNAME=
# EXPO_PUBLIC_TURN_CREDENTIAL=
# EXPO_PUBLIC_ICE_RELAY_ONLY=0

# Google Maps SDK key (required for native map tiles via PROVIDER_GOOGLE).
# Enable "Maps SDK for Android" (and "Maps SDK for iOS" if you ship iOS) in GCP.
# Does NOT enable Places / Routes — those stay on the backend and can stay locked.
# GOOGLE_MAPS_ANDROID_API_KEY=AIza...

# Lead-vehicle tracking (Crosstown prediction readiness). Default mock in __DEV__.
# EXPO_PUBLIC_LEAD_VEHICLE_TRACKING=1
# EXPO_PUBLIC_LEAD_VEHICLE_DEBUG_OVERLAY=1
# EXPO_PUBLIC_LEAD_VEHICLE_MODE=mock
# Telemetry defaults on in __DEV__; set explicitly for production builds:
EXPO_PUBLIC_LEAD_VEHICLE_TELEMETRY=1
# EXPO_PUBLIC_LEAD_VEHICLE_REMOTE=0
