# CamTok mobile env
# Copy to .env and fill in before running `pnpm start`.

# URL of the deployed Next.js backend (from the camtok web app).
# Examples:
#   local dev on a simulator:   http://localhost:3000
#   local dev on a real device: http://192.168.1.42:3000   (your machine's LAN IP)
#   production:                 https://camtok.example.com
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# Supabase — same project that camtok web uses, the anon key only.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
